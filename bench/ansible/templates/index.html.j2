<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <style>
        body { font-family: -apple-system, sans-serif; max-width: 40em; margin: 4em auto; padding: 0 1em; }
        h1 { color: #333; }
        code { background: #f4f4f4; padding: 0.1em 0.3em; border-radius: 3px; }
    </style>
</head>
<body>
    <h1>{{ title }}</h1>
    <p>This page was rendered by the bench workload to validate that
    file deploy + service reload completes correctly.</p>
    <p>Workers: <code>{{ workers }}</code></p>
    <p>Listen port: <code>{{ listen_port }}</code></p>
    <p>Document root: <code>{{ doc_root }}</code></p>
</body>
</html>
