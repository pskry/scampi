# Per-user environment values (PVE host, IP range, etc). The committed
# .env.example documents what to set; users copy it and edit.
.env

# Generated by provision.sh from .env values — never edited by hand.
ansible/inventory.ini

# Per-run timing data and metadata. Curated results live in results/published/.
results/*.csv
results/*.json
results/*.md
results/*.metadata.txt

# scampi check/apply cache for inline source content.
.scampi-cache/

# Auto-generated ephemeral SSH keypair used solely for controller →
# bench-LXC comms. Created by provision.sh, lives only as long as the bench
# LXCs do. Never committed.
.ssh/

# ansible venv (created by provision.sh from requirements.txt).
ansible/venv/
