server {
    listen {{ .listen_port }};
    listen [::]:{{ .listen_port }};

    server_name {{ .site_b_host }};

    root {{ .doc_root }}/site-b;
    index index.html;

    access_log /var/log/nginx/site_b.access.log combined_full;
    error_log  /var/log/nginx/site_b.error.log warn;

    location / {
        try_files $uri $uri/ =404;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8080/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 30s;
    }
}
