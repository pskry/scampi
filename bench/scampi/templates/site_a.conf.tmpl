server {
    listen {{ .listen_port }};
    listen [::]:{{ .listen_port }};

    server_name {{ .site_a_host }};

    root {{ .doc_root }}/site-a;
    index index.html;

    access_log /var/log/nginx/site_a.access.log combined_full;
    error_log  /var/log/nginx/site_a.error.log warn;

    location / {
        try_files $uri $uri/ =404;
    }

    location ~* \.(jpg|jpeg|png|gif|ico|css|js)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }
}
