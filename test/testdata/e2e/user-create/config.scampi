module main

import "std"
import "std/posix"
import "std/local"

let host = local.target { name = "local" }

std.deploy(name = "test", targets = [host]) {
  posix.user {
    desc   = "create user hal9000"
    name   = "hal9000"
    shell  = "/bin/bash"
    home   = "/home/hal9000"
    groups = ["sudo", "docker"]
  }
}
