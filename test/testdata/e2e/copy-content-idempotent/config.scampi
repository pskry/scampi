module main

import "std"
import "std/posix"
import "std/local"

let host = local.target { name = "local" }

std.deploy(name = "test", targets = [host]) {
  posix.copy {
    desc = "already-present sudoers entry"
    src = posix.source_inline { content = "hal9000 ALL=(ALL) NOPASSWD:ALL\n" }
    dest = "/etc/sudoers.d/hal9000"
    perm = "0440"
    owner = "testuser"
    group = "testgroup"
  }
}
