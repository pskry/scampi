module main

import "std"
import "std/posix"

let local = posix.local { name = "local" }

std.deploy(name = "test", targets = [local]) {
  posix.copy {
    desc = "copy missing file"
    src = posix.source_local { path = "/tmp/nonexistent.txt" }
    dest = "/tmp/out.txt"
    perm = "0644"
    owner = "testuser"
    group = "testgroup"
  }
}
