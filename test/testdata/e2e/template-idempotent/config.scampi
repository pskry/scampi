module main

import "std"
import "std/posix"
import "std/local"

let host = local.target { name = "local" }

std.deploy(name = "test", targets = [host]) {
  posix.template {
    desc = "already rendered"
    src = posix.source_inline { content = "hello" }
    dest = "/tmp/out.txt"
    perm = "0644"
    owner = "testuser"
    group = "testgroup"
  }
}
