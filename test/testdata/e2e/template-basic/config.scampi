module main

import "std"
import "std/posix"

let local = posix.local { name = "local" }

std.deploy(name = "test", targets = [local]) {
  posix.template {
    desc = "render greeting"
    src = posix.source_local { path = "/tmpl/greeting.txt" }
    dest = "/tmp/greeting.txt"
    data = {
      "values": {
        "name": "world",
        "count": 3,
      },
    }
    perm = "0644"
    owner = "testuser"
    group = "testgroup"
  }
}
