module main

import "std"
import "std/posix"
import "std/local"

let host = local.target { name = "local" }

std.deploy(name = "test", targets = [host]) {
  posix.pkg {
    desc     = "already configured dnf repo"
    packages = ["example-pkg"]
    source   = posix.pkg_dnf_repo { url = "https://example.com/repo/el9" }
  }
}
