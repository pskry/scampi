module main

import "std"
import "std/posix"
import "std/local"

let host = local.target { name = "local" }

std.deploy(name = "test", targets = [host]) {
  posix.pkg {
    desc     = "already at latest"
    packages = ["nginx"]
    state    = posix.PkgState.latest
    source   = posix.pkg_system {}
  }
}
