module main

import "std"
import "std/posix"

let local = posix.local { name = "local" }

std.secrets { backend = std.SecretsBackend.file, path = "/secrets.json" }

std.deploy(name = "test", targets = [local]) {
  posix.template {
    desc = "missing secret"
    content = "token={{.token}}"
    dest = "/tmp/out.txt"
    data = {
      "values": {
        "token": std.secret("nonexistent_key"),
      },
    }
    perm = "0644"
    owner = "testuser"
    group = "testgroup"
  }
}
