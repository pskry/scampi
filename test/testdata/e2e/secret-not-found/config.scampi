module main

import "std"
import "std/posix"
import "std/local"
import "std/secrets"

let host = local.target { name = "local" }
let resolver = secrets.from_file(path = "/secrets.json")

std.deploy(name = "test", targets = [host]) {
  posix.template {
    desc    = "missing secret"
    content = "token={{.token}}"
    dest    = "/tmp/out.txt"
    data    = {
      "values": {
        "token": resolver.get("nonexistent_key"),
      },
    }
    perm    = "0644"
    owner   = "testuser"
    group   = "testgroup"
  }
}
