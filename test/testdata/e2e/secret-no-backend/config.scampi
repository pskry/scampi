module main

import "std"
import "std/posix"

let local = posix.local { name = "local" }

std.deploy(name = "test", targets = [local]) {
  posix.template {
    desc = "no backend configured"
    content = "pass={{.pw}}"
    dest = "/tmp/out.txt"
    data = {
      "values": {
        "pw": std.secret("db_pass"),
      },
    }
    perm = "0644"
    owner = "testuser"
    group = "testgroup"
  }
}
