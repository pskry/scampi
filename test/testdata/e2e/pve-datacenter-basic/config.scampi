module main

import "std"
import "std/pve"
import "std/local"

let host = local.target { name = "local" }

std.deploy(name = "test", targets = [host]) {
  pve.datacenter {
    desc        = "datacenter config"
    console     = pve.Console.xtermjs
    keyboard    = "en-us"
    language    = "en"
    mac_prefix  = "BE:EF"
    max_workers = 4
    tags        = [
      pve.Tag { name = "infra", fg = "#2a5a8e", bg = "#e6f0fa" },
      pve.Tag { name = "dns",   fg = "#1a7a3a", bg = "#e6fae6" },
    ]
  }
}
