module main

import "std"
import "std/posix"

let local = posix.local { name = "local" }

std.secrets { backend = std.SecretsBackend.file, path = "/secrets.json" }

std.deploy(name = "test", targets = [local]) {
  posix.template {
    desc = "render with secret"
    src = posix.source_inline { content = "dsn=postgres://app:{{.db_pass}}@db:5432/myapp" }
    dest = "/tmp/dsn.txt"
    data = {
      "values": {
        "db_pass": std.secret("db_pass"),
      },
    }
    perm = "0600"
    owner = "testuser"
    group = "testgroup"
  }
}
