module main

import "std"
import "std/posix"

let local = posix.local { name = "local" }

std.deploy(name = "test", targets = [local]) {
  posix.user {
    desc = "modify user shell and groups"
    name = "hal9000"
    shell = "/bin/zsh"
    home = "/home/hal9000"
    groups = ["sudo", "docker"]
  }
}
