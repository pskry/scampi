module main

import "std"
import "std/posix"
import "std/local"

let host = local.target { name = "local" }

std.deploy(name = "test", targets = [host]) {
  posix.copy {
    desc = "copy with bad permission"
    src = posix.source_local { path = "/src.txt" }
    dest = "/dest.txt"
    perm = "invalid"
    owner = "testuser"
    group = "testgroup"
  }
}
