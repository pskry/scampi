module main

import "std"
import "std/posix"
import "std/local"

let host = local.target { name = "local" }

std.deploy(name = "test", targets = [host]) {
  posix.copy {
    desc = "copy with invalid perm"
    src = posix.source_local { path = "/tmp/src.txt" }
    dest = "/tmp/dest.txt"
    perm = "bad"
    owner = "root"
    group = "root"
  }
}
