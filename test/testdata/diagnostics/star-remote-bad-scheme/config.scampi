module main

import "std"
import "std/posix"

let host = posix.local { name = "host" }

std.deploy(name = "main", targets = [host]) {
  posix.copy {
    src = posix.source_remote { url = "ftp://files.example.com/config.tar.gz" }
    dest = "/tmp/out"
    perm = "0644"
    owner = "root"
    group = "root"
  }
}
