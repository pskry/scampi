module main

import "std"
import "std/posix"

let local = posix.local { name = "local" }

std.deploy(name = "test", targets = [local]) {
  posix.copy {
    desc = "copy with relative dest"
    src = posix.source_local { path = "/tmp/src.txt" }
    dest = "./relative/dest.txt"
    perm = "0644"
    owner = "user"
    group = "group"
  }
}
