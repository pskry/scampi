module main

import "std"
import "std/posix"
import "std/local"

let host = local.target { name = "local" }

std.deploy(name = "test", targets = [host]) {
  posix.copy {
    desc  = "copy with relative dest"
    src   = posix.source_local { path = "/tmp/src.txt" }
    dest  = "./relative/dest.txt"
    perm  = "0644"
    owner = "user"
    group = "group"
  }
}
