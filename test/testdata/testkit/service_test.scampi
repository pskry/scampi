module main

import "std"
import "std/posix"
import "std/test"
import "std/test/matchers"

let mock = test.target_in_memory(
  name = "mock",
  initial = test.InitialState {
    services = { "nginx": posix.ServiceState.stopped },
  },
  expect = test.ExpectedState {
    services = {
      "nginx": matchers.has_svc_status(posix.ServiceState.running),
    },
  },
)

std.deploy(name = "services", targets = [mock]) {
  posix.service {
    name  = "nginx"
    state = posix.ServiceState.running
  }
}
