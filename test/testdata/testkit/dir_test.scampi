module main

import "std"
import "std/posix"
import "std/test"
import "std/test/matchers"

let mock = test.target_in_memory(
  name = "mock",
  initial = test.InitialState {
    dirs = ["/var"],
  },
  expect = test.ExpectedState {
    dirs = {
      "/var/www":        matchers.is_present(),
      "/var/www/mysite": matchers.is_present(),
      "/nonexistent":    matchers.is_absent(),
    },
  },
)

std.deploy(name = "dirs", targets = [mock]) {
  posix.dir { path = "/var/www" }
  posix.dir { path = "/var/www/mysite" }
}
