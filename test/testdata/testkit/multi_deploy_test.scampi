module main

// Test multiple deploy blocks against the same target. The two
// deploys share the mock; verification runs once at the end against
// the combined post-apply state.

import "std"
import "std/posix"
import "std/test"
import "std/test/matchers"

let mock = test.target_in_memory(
  name = "mock",
  initial = test.InitialState {
    dirs = ["/etc", "/var/log"],
  },
  expect = test.ExpectedState {
    // From base deploy
    dirs = {
      "/etc/app":     matchers.is_present(),
      "/var/log/app": matchers.is_present(),
    },
    packages = {
      "curl": matchers.has_pkg_status(posix.PkgState.present),
    },
    // From app deploy
    files = {
      "/etc/app/config.yml": matchers.has_substring("debug: false"),
    },
  },
)

std.deploy(name = "base", targets = [mock]) {
  posix.dir { path = "/etc/app" }
  posix.dir { path = "/var/log/app" }
  posix.pkg {
    packages = ["curl"]
    source   = posix.pkg_system {}
  }
}

std.deploy(name = "app", targets = [mock]) {
  posix.dir { path = "/etc/app" }
  posix.copy {
    desc  = "app config"
    dest  = "/etc/app/config.yml"
    src   = posix.source_inline { content = "debug: false\nport: 3000\n" }
    perm  = "0644"
    owner = "root"
    group = "root"
  }
}
