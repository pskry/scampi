module main

import "std"
import "std/posix"
import "std/test"
import "std/test/matchers"

let mock = test.target_in_memory(
  name = "mock",
  initial = test.InitialState {
    dirs = ["/opt"],
  },
  expect = test.ExpectedState {
    symlinks = {
      "/opt/app/current":     matchers.has_exact_content("/opt/app/releases/v1"),
      "/opt/app/nonexistent": matchers.is_absent(),
    },
    files = {
      "/opt/app/releases/v1/config.yml": matchers.has_substring("port: 8080"),
    },
    dirs = {
      "/opt/app/releases/v1": matchers.is_present(),
    },
  },
)

std.deploy(name = "links", targets = [mock]) {
  posix.dir { path = "/opt/app" }
  posix.dir { path = "/opt/app/releases" }
  posix.dir { path = "/opt/app/releases/v1" }
  posix.symlink {
    link   = "/opt/app/current"
    target = "/opt/app/releases/v1"
  }
  posix.copy {
    desc  = "app config"
    dest  = "/opt/app/releases/v1/config.yml"
    src   = posix.source_inline { content = "port: 8080\nenv: production\n" }
    perm  = "0644"
    owner = "root"
    group = "root"
  }
}
