module main

import "std"
import "std/posix"
import "std/test"
import "std/test/matchers"

let mock = test.target_in_memory(
  name = "mock",
  expect = test.ExpectedState {
    packages = {
      "nginx":   matchers.has_pkg_status(posix.PkgState.present),
      "curl":    matchers.has_pkg_status(posix.PkgState.present),
      "apache2": matchers.has_pkg_status(posix.PkgState.absent),
    },
  },
)

std.deploy(name = "packages", targets = [mock]) {
  posix.pkg {
    packages = ["nginx", "curl"]
    source   = posix.pkg_system {}
  }
}
