module main

import "std"
import "std/posix"
import "std/test"
import "std/test/matchers"

let mock = test.target_in_memory(
  name = "mock",
  initial = test.InitialState {
    files = {
      "/etc/existing.conf": posix.source_inline { content = "old content" },
    },
  },
  expect = test.ExpectedState {
    files = {
      "/etc/app.conf":      matchers.has_exact_content("server_name example.com\nlisten 80\n"),
      "/etc/existing.conf": matchers.is_present(),
      "/nonexistent":       matchers.is_absent(),
    },
  },
)

std.deploy(name = "files", targets = [mock]) {
  posix.copy {
    desc  = "write config"
    dest  = "/etc/app.conf"
    src   = posix.source_inline { content = "server_name example.com\nlisten 80\n" }
    perm  = "0644"
    owner = "root"
    group = "root"
  }
}
