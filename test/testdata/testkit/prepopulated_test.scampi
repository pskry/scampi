module main

// Test that pre-populated target state is preserved and modified
// correctly. The target starts with existing files, packages, and
// services — steps should converge without clobbering unrelated
// state.

import "std"
import "std/posix"
import "std/test"
import "std/test/matchers"

let mock = test.target_in_memory(
  name = "mock",
  initial = test.InitialState {
    files = {
      "/etc/hostname": posix.source_inline { content = "old-host" },
      "/etc/motd":     posix.source_inline { content = "welcome" },
    },
    packages = ["curl", "git"],
    services = { "sshd": posix.ServiceState.running },
    dirs     = ["/home/deploy", "/var/log"],
  },
  expect = test.ExpectedState {
    // Changed state
    files = {
      "/etc/hostname": matchers.has_exact_content("new-host"),
      // Preserved state — not touched by steps
      "/etc/motd":     matchers.has_exact_content("welcome"),
    },
    packages = {
      "nginx": matchers.has_pkg_status(posix.PkgState.present),
      "curl":  matchers.has_pkg_status(posix.PkgState.present),
      "git":   matchers.has_pkg_status(posix.PkgState.present),
    },
    services = {
      "sshd": matchers.has_svc_status(posix.ServiceState.running),
    },
    dirs = {
      "/var/log/app": matchers.is_present(),
      "/home/deploy": matchers.is_present(),
    },
  },
)

std.deploy(name = "converge", targets = [mock]) {
  // Overwrite hostname
  posix.copy {
    desc  = "set hostname"
    dest  = "/etc/hostname"
    src   = posix.source_inline { content = "new-host" }
    perm  = "0644"
    owner = "root"
    group = "root"
  }
  // Install additional package
  posix.pkg {
    packages = ["nginx"]
    source   = posix.pkg_system {}
  }
  // Add a directory
  posix.dir { path = "/var/log/app" }
}
